import java.util.*;
public class Main
{
	public static void main(String[] args) {
	  Scanner sc=new Scanner(System.in);
	  int t=sc.nextInt();
	  while(t-->0){
	  int n=sc.nextInt();
	  int m=sc.nextInt();
	  int total=0;
	  for(int i=0;i<n;i++){
	      int max=Integer.MIN_VALUE;
	      for(int j=0;j<m;j++){
	          int x=sc.nextInt();
	          max=Math.max(max,x);
	      }
	      total+=max;
	  }
	  System.out.println(total);
	}}
}
