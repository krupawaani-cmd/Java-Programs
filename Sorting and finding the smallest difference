       int t=sc.nextInt();
       while(t-->0){
           int n=sc.nextInt();
           int arr[]=new int[n];
           for(int i=0;i<n;i++){
               arr[i]=sc.nextInt();
           }
           Arrays.sort(arr);
           int min=arr[1]-arr[0];
           for(int i=1;i<n-1;i++){
               int diff=arr[i+1]-arr[i];
           
