Input Format

Input consists of a single integer n.

Constraints

-10^9 <= n <= 10^9

Output Format

Print a single integer representing the generated integrity value.

Sample Input 0

5821
Sample Output 0

16
Sample Input 1

-900045
Sample Output 1

-18

import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        /* Enter your code here. Read input from STDIN. Print output to STDOUT. Your class should be named Solution. */
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int sign=1;
        if(n<0){
            sign=-1;
            n=-n;
        }
        int sum=0;
        while(n>0){
            sum=sum+(n%10);
            n=n/10;
        }
       System.out.print(sum*sign);

        
    }
}
